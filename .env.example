# Container Club — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs.
# NE JAMAIS commit .env.local

# ============================================
# SUPABASE
# ============================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Project ref (pour CLI Supabase)
SUPABASE_PROJECT_ID=

# ============================================
# STRIPE (mode test au démarrage)
# ============================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ============================================
# STRIPE INTEGRATION (session 1) — voir docs/stripe-setup.md
# ============================================
# Variables server-only (NE PAS préfixer VITE_).
# Décommenter et remplir une fois Stripe configuré côté dashboard.
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Supabase service role (RLS bypass) — server-only.
# Utilisé par le webhook Stripe et createCheckoutSession.
# SUPABASE_SERVICE_ROLE_KEY=eyJxxx
# SUPABASE_URL=https://mkfztwibolswqcggukeq.supabase.co

# ============================================
# BREVO (emails transactionnels — API HTTP, compatible Cloudflare Workers)
# ============================================
# Sans BREVO_API_KEY, chaque envoi est un no-op silencieux
# ({ skipped: true, reason: 'not_configured' }) — les flux (réservation,
# candidature partenaire, stock) aboutissent quand même, sans email.
BREVO_API_KEY=xkeysib-
# Expéditeur au format "Nom <email>" ou "email" (domaine vérifié dans Brevo).
BREVO_FROM=Container Club <contact@prosimport.com>
# Destinataire des notifs admin (réservations, candidatures, stock).
# Fallback: adrienlaniez1@gmail.com
ADMIN_NOTIFICATION_EMAIL=adrienlaniez1@gmail.com

# ============================================
# INSEE SIRENE API (vérification SIRET) — V1.3
# ============================================
# Crée ton compte sur https://portail-api.insee.fr/
INSEE_API_KEY=
INSEE_API_BASE_URL=https://api.insee.fr/api-sirene/3.11
INSEE_OAUTH_URL=https://api.insee.fr/token
INSEE_CLIENT_ID=
INSEE_CLIENT_SECRET=

# ============================================
# CLOUDFLARE
# ============================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGES_HASH=
CLOUDFLARE_R2_BUCKET=

# ============================================
# ANALYTICS & MONITORING
# ============================================
VITE_PLAUSIBLE_DOMAIN=prosimport.com
VITE_PLAUSIBLE_API_HOST=https://plausible.io

VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=container-club

# ============================================
# RATE LIMITING — V2 (optionnel, V1 utilise Cloudflare WAF)
# ============================================
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ============================================
# SÉCURITÉ — V1.3
# ============================================
# Domaines emails personnels (warning, pas blocage)
BLOCKED_EMAIL_DOMAINS_WARN=gmail.com,yahoo.com,yahoo.fr,hotmail.com,hotmail.fr,outlook.com,outlook.fr,free.fr,orange.fr,wanadoo.fr,laposte.net,sfr.fr,bbox.fr,neuf.fr,icloud.com,me.com

# ============================================
# BUSINESS CONFIG (overridable via app_config DB)
# ============================================
DEFAULT_VAT_RATE=20
RESERVATION_FEE_RATE=0.03
RESERVATION_FEE_MIN=150
RESERVATION_FEE_MAX=500
CONTAINER_CAPACITY_CBM=28
CONTAINER_THRESHOLD_PERCENT=80
MIN_SERIES_REQUIRED=3
CONTAINER_AUTO_OPEN_MODE=manual

# ============================================
# ENVIRONNEMENT
# ============================================
NODE_ENV=development
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME=Container Club
